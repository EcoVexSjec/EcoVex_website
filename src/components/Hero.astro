---
import Layout from "../layouts/Layout.astro"
---
<Layout>
<div id = "hero">
<h1>Bridging <span class = "gradient">Nature</span><br>with <span class = "gradient">Technology</span></h1>
<p>Welcome to the college Eco Club. We are redesigning sustainability<br>through digital innovation and community action.</p>
<button>Join Us</button>
</div>
</Layout>


<style >
    
    *{
        padding: 0px;
        margin: 0px;
    }
    #hero{
        
        background-color: black;
        height: 100vh;
        text-align: center;
    }
    h1{
        font-size: 80px;
        color: white;
        text-align: center;
        padding-top: 30vh;
    }
    .gradient{
        background: linear-gradient(135deg, #4a7c44 0%, #34e9bd 100%);
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
    }
    p{
        color: #a0ac9f;
        font-size: 24px;
        text-align: center;
        margin-top: 35px;
    }
    button{
        color:#a0ac9f;
        border: 2px solid #34e9bd;
        background-color: transparent;
        height: 61px;
        width: 150px;
        border-radius: 50px;
        text-align: center;
        margin-top: 50px;
        text-transform: uppercase;
        font-size: 16px;   
    }
</style>

