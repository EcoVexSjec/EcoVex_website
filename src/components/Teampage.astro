---
import Layout from "../layouts/Layout.astro"
---

<Layout>
    <div class = "main">
        <h1>Meet the <span class="gradient">Visionaries</span></h1>
        <div id="card_container">
        <div class="card">
            <div class = "img"></div>
            <h3 class="name">Name</h3>
            <p class="position">Position</p>
            <p class="slogan">Slogan</p>
            <div class="contact"></div>
        </div>
        <div class="card">
            <div class="img"></div>
            <h3 class="name">Name</h3>
            <p class="position">Position</p>
            <p class="slogan">Slogan</p>
            <div class="contact"></div>
        </div>
        <div class="card">
            <div class="img"></div>
            <h3 class="name">Name</h3>
            <p class="position">Position</p>
            <p class="slogan">Slogan</p>
            <div class="contact"></div>
        </div>
        <div class="card">
            <div class="img"></div>
            <h3 class="name">Name</h3>
            <p class="position">Position</p>
            <p class="slogan">Slogan</p>
            <div class="contact"></div>
        </div>
        <div class="card">
            <div class="img"></div>
            <h3 class="name">Name</h3>
            <p class="position">Position</p>
            <p class="slogan">Slogan</p>
            <div class="contact"></div>
        </div>
        <div class="card">
            <div class="img"></div>
            <h3 class="name">Name</h3>
            <p class="position">Position</p>
            <p class="slogan">Slogan</p>
            <div class="contact"></div>
        </div>
        <div class="card">
            <div class="img"></div>
            <h3 class="name">Name</h3>
            <p class="position">Position</p>
            <p class="slogan">Slogan</p>
            <div class="contact"></div>
        </div>
        <div class="card">
            <div class="img"></div>
            <h3 class="name">Name</h3>
            <p class="position">Position</p>
            <p class="slogan">Slogan</p>
            <div class="contact"></div>
        </div>
    </div>
</div>
</Layout>

<style>
    *{
        margin: 0px;
        padding: 0px;
        box-sizing: border-box;
    }
    .main{
        min-height: 140vh; 
        height: auto;
        background-color:#0a0f0a ;
    }
    h1{
        font-size: 48px;
        color: #e0f2f1;
        text-align: center;
        padding-top: 130px;
        padding-bottom: 100px;
    }
    .gradient{
        background: linear-gradient(135deg, #4a7c44 0%, #34e9bd 100%);
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
    }
    .card{
        background-color: #0a0f0a;;
        border: 1px solid #ffffff1a;
        text-align: center;
        margin: 20px;
        padding: 40px;
        border-radius: 20px;
        margin-left: auto;
        margin-right: auto;
    }
    #card_container{
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(300px,1fr));
        gap:15px;
        justify-content: center;
        margin-left: 150px;
        margin-right: 150px;
        margin-top: 50px;
    }
    .img{
        height: 200px;
        width: 200px;
        border-radius: 50%;
        border: 5px solid #34e9bd;
        background-image: url("/logo1.jpeg");
        background-size: cover;
        background-position: center;    
        background-repeat: no-repeat;
    }
    .name
    {
        padding-top: 20px;
        font-size: 22.4px;
        color: #e0f2f1;
    }
    .position{
        font-size: 14.4px;
        color:#34e9bd;
    }
    .slogan{
        padding: 20px;
        font-size: 13.6px;
        color: #a0ac9f;
    }
</style>