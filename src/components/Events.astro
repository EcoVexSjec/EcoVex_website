        </div>
        </div>
</div>
</Layout>

<style>
*{
    margin:0;
    padding:0;
    box-sizing: border-box;
}
#main{
    min-height: 170vh;
    height: auto;
    background-color:#0a0f0a ;
}
.container{
        background-color: #0096880D;
        border: 1px solid rgba(0, 150, 136, 0.2);
        text-align: center;
        border-radius: 20px;
        margin: 20px;
        padding: 40px;
        border-radius: 20px;
        justify-items: start;
}
#project{
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 20px;
    justify-content: center;
    margin-left: 150px;
    margin-right: 150px;
}
.img{
    background-color: #ffffff1a;
    border-radius: 50%;
    margin-bottom: 30px;
    width: 100px;
    height: 100px;
    margin-left: auto;
    margin-right: auto;
    background-image: url("/logo.png");
    background-size:contain;
    background-position: center;
    background-repeat: no-repeat;
    margin-top: 15px;
    border: 2px solid rgba(0, 150, 136, 0.2);
}
.container:hover{
    translate: 0 -5px;
    box-shadow: rgba(52, 211, 153, 0.3) 0px 10px 30px -10px;
    .img{
        translate: 0 -1px;
        scale: 1.05;
    }
}
.time{
    color: #e0f2f1;
    font-size: 12px;
    margin-bottom: 20px;
    margin-left: auto;
    margin-right: auto;
}
.title{
    color: #e0f2f1;
    font-size: 20px;
    margin-bottom: 20px;
    padding-left: 30px;
}
.content{
    color: #a0ac9f;
    font-size: 16px;
    margin-bottom: 90px;
}
.type{
        border: 1px solid #a0ac9f;
        background-color: #ffffff0D;
        color:#a0ac9f;
        border-radius: 15px;
        font-size: 12px;
        padding: 6px 20px;
        margin-right: 15px;
}

.progress{
        border: 1px solid #ffffff1a;
        background-color: #10FB981A;
        padding: 6px 20px;
        color:#e0f2f1;
        border-radius: 15px;
        font-size: 12px;
}
.incomplete{
        border: 1px solid #ffffff1a;
        background-color: #2D1A1A;
        color:#e0f2f1;
        border-radius: 15px;
        font-size: 12px;
        padding: 6px 20px;
}
#head{
        font-size: 48px;
        color: #e0f2f1;
        text-align: center;
        padding-top: 130px;
}
.gradient{
        background: linear-gradient(135deg, #4a7c44 0%, #34e9bd 100%);
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
}
#para{
        color: #a0ac9f;
        font-size: 18px;
        text-align: center;
        margin-top: 10px;
        padding-bottom: 100px;
        padding-left: 30px;
        padding-right: 30px;
 }
 a{
    text-decoration: none;
 }
</style>