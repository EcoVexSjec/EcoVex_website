<script>
  import Swiper from 'swiper';
  import { Navigation } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/navigation';

  new Swiper('.mySwiper', {
    modules: [Navigation],
    navigation: {
      nextEl: '.swiper-button-next',
      prevEl: '.swiper-button-prev',
    },
    breakpoints: {
      // Desktop: Remains a static grid as per image_e501a8.png
      901: {
        enabled: false,
      },
      // Mobile: Cards closer together with no overlap
      0: {
        enabled: true,
        // slidesPerView: 1.15 shows a peek of the next card without squishing
        slidesPerView: 1.15, 
        centeredSlides: false, 
        spaceBetween: 10,
        // Small padding to prevent touching screen edges
        slidesOffsetBefore: 15, 
        slidesOffsetAfter: 15,
      }
    }
  });
</script>
  

